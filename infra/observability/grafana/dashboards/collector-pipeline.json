      "targets": [
        { "expr": "sum(rate(otelcol_receiver_accepted_spans[5m]))", "legendFormat": "accepted spans", "refId": "A" },
        { "expr": "sum(rate(otelcol_receiver_accepted_metric_points[5m]))", "legendFormat": "accepted metric points", "refId": "B" },
        { "expr": "sum(rate(otelcol_receiver_accepted_log_records[5m]))", "legendFormat": "accepted logs", "refId": "C" }
      ],
      "title": "Collector 接收量",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "sum(rate(otelcol_exporter_sent_spans[5m]))", "legendFormat": "sent spans", "refId": "A" },
        { "expr": "sum(rate(otelcol_exporter_sent_metric_points[5m]))", "legendFormat": "sent metric points", "refId": "B" },
        { "expr": "sum(rate(otelcol_exporter_sent_log_records[5m]))", "legendFormat": "sent logs", "refId": "C" }
      ],
      "title": "Collector 导出成功量",
