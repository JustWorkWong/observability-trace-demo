{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        { "expr": "sum(rate(orders_created_total[5m]))", "legendFormat": "成功", "refId": "A" },
        { "expr": "sum(rate(orders_failed_total[5m]))", "legendFormat": "失败", "refId": "B" }
      ],
      "title": "订单成功 / 失败速率",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(order_create_duration_ms_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(order_create_duration_ms_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "B" }
      ],
      "title": "订单创建耗时 P95 / P99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_client_request_duration_seconds_bucket{service_name=\"orderservice\"}[5m])) by (le)) * 1000", "legendFormat": "order -> inventory p95", "refId": "A" }
      ],
      "title": "跨服务调用耗时",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": ["observability", "order"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
