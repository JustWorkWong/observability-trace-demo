{
  "Logging": {
    "LogLevel": {
      // 订单服务保留 Information，便于从日志理解一次下单做了哪些动作。
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "ServiceName": "orderservice",
    "ServiceNamespace": "observability-trace-demo",
    "ServiceVersion": "1.0.0",
    // 这里既是默认值，也是教学提示：真实导出地址通常由 AppHost 环境变量覆盖。
    "OtlpEndpoint": "http://localhost:14318",
    "DeploymentEnvironment": "Development"
  },
  "DownstreamServices": {
    // 默认由服务发现解析为 InventoryService。
    // 如果要脱离 AppHost 单独调试，可通过环境变量覆盖成固定 URL。
    "InventoryServiceBaseAddress": "https+http://inventoryservice"
  },
  "ConnectionStrings": {
    // PostgreSQL 真实连接串由 AppHost 在运行时注入。
    // 保留空值是为了提醒读者：代码依赖这个键名，而不是把连接串写死在仓库里。
    "observabilitydb": ""
  }
}
